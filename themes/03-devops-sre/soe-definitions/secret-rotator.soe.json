{
  "agentId": "secret-rotator",
  "version": "1.0.0",
  "description": "Secret rotation agent that can trigger credential rotations through the vault API and read rotation schedules. Strictly prohibited from reading plaintext secrets, exporting secrets, or transmitting secrets externally.",
  "complianceFrameworks": ["soc2", "iso27001", "nist-800-53", "pci-dss"],
  "identity": {
    "role": "SecretManager",
    "allowedPersonas": ["secret-rotator"],
    "authorityLevel": "rotate-only",
    "environmentScope": ["production", "uat", "development"],
    "dataClassification": "restricted"
  },
  "dataAccess": {
    "readAllow": [
      "vault/rotation-schedules/**",
      "vault/rotation-logs/**",
      "vault/policies/**",
      "vault/metadata/**",
      "security/rotation-config/**"
    ],
    "readDeny": [
      "vault/secrets/**",
      "vault/plaintext/**",
      "**/credentials*",
      "**/.env*",
      "**/secrets*",
      "**/api-key*",
      "**/password*",
      "**/private-key*",
      "**/service-account-key*",
      "**/connection-string*",
      "**/token*"
    ],
    "writeAllow": [
      "vault/rotation-logs/**",
      "vault/rotation-status/**"
    ],
    "writeDeny": [
      "vault/secrets/**",
      "vault/plaintext/**",
      "**/credentials*",
      "**/.env*",
      "production/**",
      "customer-data/**"
    ]
  },
  "toolActions": {
    "allowed": [
      "trigger_rotation",
      "check_rotation_status",
      "read_rotation_schedule",
      "verify_rotation"
    ],
    "denied": [
      "read_plaintext_secret",
      "export_secrets",
      "transmit_secret_external",
      "delete_secret"
    ],
    "bash": {
      "allow": [
        "vault write *rotate*",
        "vault write sys/rotate*",
        "vault read *rotation-status*",
        "vault list *rotation-schedules*",
        "cat vault/rotation-schedules/**",
        "cat vault/rotation-logs/**"
      ],
      "deny": [
        "vault kv get *",
        "vault read secret/*",
        "vault kv export *",
        "vault secrets *",
        "vault token create *",
        "curl * -X POST *external*",
        "curl * -X POST *webhook*",
        "curl * -d *secret*",
        "curl * -d *password*",
        "curl * -d *token*",
        "curl * -d *key*",
        "wget *",
        "nc *",
        "rm -rf *",
        "sudo *",
        "eval *"
      ]
    }
  },
  "riskBudget": {
    "maxPerSession": 20,
    "thresholds": {
      "warn": 10,
      "throttle": 15,
      "critical": 18,
      "exhausted": 20
    }
  }
}
